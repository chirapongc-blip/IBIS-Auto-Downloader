    var dClientEpochTime = dClient.getTime() / 1000;
    var dServerEpochTime = dClientEpochTime + updateSimpleUtcServerTimeClockDiff;

    var d = new Date(dServerEpochTime * 1000);

    var h = d.getUTCHours();
    var m = d.getUTCMinutes();
    var s = d.getUTCSeconds();

    if (h < 10) { h = "0" + h; }
    if (m < 10) { m = "0" + m; }

    $('#simpleUtcServerTimeClock').html(h + ":" + m + " UTC");

    setTimeout(updateSimpleUtcServerTimeClock, 1000);
}


function InitSimpleUtcServerTimeClock(serverEpochTime) {

    var dServerEpochTime = new Date(serverEpochTime);
    var dClient = new Date();
    var dClientEpochTime = dClient.getTime() / 1000;

    updateSimpleUtcServerTimeClockDiff = dServerEpochTime - dClientEpochTime;

    updateSimpleUtcServerTimeClock();
