window.PreferenceManager = {

    url: null,

    setup: function (url) {
        this.url = url;
    },

    submit: function (request, callback) {
        $.ajax({
            type: "POST",
            url: this.url,
            data: JSON.stringify(request),
            contentType: "application/json",
            dataType: "json",
            success: function (input) {
                if (callback) {
                    callback(input);
                }
            },
            error: function (input) {
                console.log(input);
            }
        });
    },

    put: function (name, value, callback) {
        var request = { Name: name, Value: value };
        this.submit(request, callback);
    },

    restoreDefaults: function (callback) {
        var request = { Restore: true };
        this.submit(request, callback);
    },
};;
window.UploadManager = {

    config: null,

    init: function (config) {
        this.config = config;
        var self = this;
        this.config.input.on("change", function () {
            var file = self.config.input[0].files[0];
            self.submit(file, function (uploadSuccess) 
            { 
                if(uploadSuccess) {
                    window.location.reload(true);
                }
                else {
                    self.config.input[0].value = '';
                    config.message.innerHTML = "Upload Failed.";
                } 
            });
        });
    },

    showopen: function () {
        this.config.input.click();
    },

    submit: function (file, callback) {
        var request = new FormData();
        request.append("file", file);
        request.append("id", this.config.id);

        $.ajax({
            type: "POST",
            url: this.config.url,
            data: request,
            contentType: false,
            processData: false,
            success: function (input) {
                if (callback) {
                    callback(input);
                }
            },
            error: function (input) {
                console.log(input);
            }
        });
    },
};;
function registerGridResize() {
    window.addEventListener('resize', function (evt) {
        if (!ASPxClientUtils.androidPlatform)
            return;
        var activeElement = document.activeElement;
        if (activeElement && (activeElement.tagName === "INPUT" || activeElement.tagName === "TEXTAREA") && activeElement.scrollIntoViewIfNeeded)
            window.setTimeout(function () { activeElement.scrollIntoViewIfNeeded(); }, 0);
    });

    ASPxClientControl.GetControlCollection().ControlsInitialized.AddHandler(function (s, e) {
        UpdateGridHeight();
    });
    ASPxClientControl.GetControlCollection().BrowserWindowResized.AddHandler(function (s, e) {
        UpdateGridHeight();
    });
}

function refreshGrid(grid) {
    grid.SetHeight(0);
    var containerHeight = ASPxClientUtils.GetDocumentClientHeight();
    if (document.body.scrollHeight > containerHeight) {
        containerHeight = document.body.scrollHeight;
    }
    grid.SetHeight(containerHeight);
}


function onSearchSuccess(data) {
    if (data.RedirectUrl) {
        window.location.href = data.RedirectUrl;
    }
    else {
        $('#modalContainer').html(data);
        var dataTable = $("#searchResultTable").DataTable({
            scrollY: "200px",
            scrollX: true,
            scrollCollapse: true,
            //sorting: false,
        });
        $('#searchResultModal').on('shown.bs.modal', function (e) {
            dataTable.columns.adjust();
        });
        $('#searchResultModal').modal('show');
    }
}

function onSearchFailure(data) {
    $('#modalContainer').html(data);
    $('#searchResultModal').modal('show');
}

function smartBitsToBytes(bits) {
    if (bits < 8)
        return bits + " bits";

    return smartBytes(bits / 8);
}

function smartBytes(bytes) {

    const kib = 1024;
    const mib = 1048576;
    const gib = 1073741824;
    const tib = 1099511627776;

    if (bytes <= kib * 8)
        return bytes + " bytes";
    if (bytes < mib)
        return (bytes / kib).toFixed(2) + " KiB";
    if (bytes < gib)
        return (bytes / mib).toFixed(2) + " MiB";
    if (bytes < tib)
        return (bytes / gib).toFixed(2) + " GiB";

    return (bytes / tib).toFixed(2) + " TiB";
}

function smartBitsToBytesBase1000(bits) {
    if (bits < 8)
        return bits + " bits";

    return smartBytesBase1000(bits / 8);
}

function smartBytesBase1000(bytes) {

    const kb = 1000;
    const mb = 1000000;
    const gb = 1000000000;
    const tb = 1000000000000;

    if (bytes <= kb * 8)
        return bytes + " bytes";
    if (bytes < mb)
        return (bytes / kb).toFixed(2) + " KB";
    if (bytes < gb)
        return (bytes / mb).toFixed(2) + " MB";
    if (bytes < tb)
        return (bytes / gb).toFixed(2) + " GB";

    return (bytes / tb).toFixed(2) + " TB";
}

function smartBits(input) {

    const k = 1000;
    const m = 1000000;
    const g = 1000000000;
    const t = 1000000000000;

    // https://nl.wikipedia.org/wiki/Kilobit_per_seconde
    if (input < k)
        return input + " bit";
    if (input < m)
        return (input / k).toFixed(2) + " kbit";
    if (input < g)
        return (input / m).toFixed(2) + " Mbit";
    if (input < t)
        return (input / g).toFixed(2) + " Gbit";

    return (input / t).toFixed(2) + " Tbit";
}

function formatSecondsToTimeString(seconds, short) {
    let minutes = Math.floor(seconds / 60);
    let remainingSeconds = seconds % 60;

    let minuteString = short ? "m" : (minutes === 1) ? "minute" : "minutes";
    let secondString = short ? "s" : (remainingSeconds === 1) ? "second" : "seconds";

    return short ? `${minutes}${minuteString}${remainingSeconds}${secondString}` : `${minutes} ${minuteString}, ${remainingSeconds} ${secondString}`;
}

function formatNumberToLocaleString(value, numberOfDecimals) {
    return value.toLocaleString(undefined, {
        minimumFractionDigits: numberOfDecimals,
        maximumFractionDigits: numberOfDecimals
    });
