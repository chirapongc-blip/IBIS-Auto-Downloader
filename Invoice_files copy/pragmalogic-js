document.addEventListener('submit', function (e) {
    var form = e.target;
    setTimeout(function () {
        // Standard HTML submit buttons
        form.querySelectorAll('[type="submit"]').forEach(function (btn) {
            btn.disabled = true;
        });
        // DevExtreme buttons with useSubmitBehavior: true contain a .dx-button-submit-input
        // and must be disabled via the widget API, since programmatic .click() bypasses
        // the disabled attribute on the underlying input element.
        if (typeof $ !== 'undefined' && $.fn.dxButton) {
            document.querySelectorAll('.dx-button').forEach(function (el) {
                if (el.querySelector('.dx-button-submit-input')) {
                    $(el).dxButton('option', 'disabled', true);
                }
            });
        }
    }, 0);
});
