/* ASPxVerticalGrid */
.dxvg a:-moz-any-link:focus {
    outline: 1px dotted;
}
.dxvgER .dxvgEB,
.dxvgCR .dxvgCB 
{
    display: none;
}

.dxvgFC 
{
    position: fixed;
    z-index: 1;
}
.dxpc-content .dxvgFC
{
    position: absolute;
    top: auto !important;
    left: auto !important;
}

tr.dxvgLVR:not(.dxvgER):not(.dxvgCR) > *,
tr.dxvgLVR.dxvgCR > *
{
    border-bottom-width: 0!important;
}

.dxvgERV .dxvgHEC
{
    display: none;
}

/* Conditional formating*/
.dxFCRule
{
    position: relative;
}
.dxFCRule:before
{
    content: "";
    position: absolute;
    top: 50%;
    bottom: 50%;
    width: 16px;
    height: 16px;
    margin-top: -8px;
}
td.dxFCRule:before,
td.dx-al.dxFCRule:before,
td[align='left'].dxFCRule:before
{
    right: 2px;
    left: auto;
}
td.dx-ar.dxFCRule:before,
td[align='right'].dxFCRule:before
{
    left: 2px;
    right: auto;
}

/* ASPxImageGallery */
.dxigExpandedText
{
    overflow: visible !important;
    white-space: normal !important;
}
.dxigFVIT
{
    display: none;
}
.dxigOPWM
{
    position: relative;
    background-color: #000;
    background-color: rgba(0, 0, 0, 0);
}
.dxig-img 
{
	visibility:hidden;
}
