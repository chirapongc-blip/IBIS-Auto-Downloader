}

.dxgvControl_MetropolisBlue .dxgvHFSD {
  height: 1px;
  margin: 2px 0;
}

.dxgvControl_MetropolisBlue .dxgvHFDRC {
  margin: 15px 15px 25px;
}

.dxgvControl_MetropolisBlue .dxgvHFDRP {
  margin-left: 15px;
  margin-right: 15px;
