	left: 1px;
}
.dxTouchUI .dxfm-fileContainer .dxfm-file > .dxichSys,
.dxfm-fileContainer .dxfm-file.dxfm-fileH > .dxichSys,
.dxfm-fileContainer.dxfm-faShowCheckBoxes .dxfm-file > .dxichSys
