/* Color edit */
.dxcpColorAreaSys {
	background-image: url('/DXR.axd?r=1_176-id8Yv');
	position: relative;
	width: 290px;
	height: 240px;
	overflow: hidden;
	cursor: crosshair;
}
.dxcpHueAreaSys {
	position: relative;
	margin-left: 3px;
	width: 35px;
	height: 242px;
}
.dxcpHueAreaImageSys {
	background-image: url('/DXR.axd?r=1_178-id8Yv');
	position: absolute;
	left: 6px;
	width: 21px;
    height: 240px;
}
.dxcpColorAreaSys,
.dxcpHueAreaSys {
	-webkit-touch-callout: none;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-ms-user-select: none;
	user-select: none;
}
.dxcpColorPointerSys {
	background-image: url('/DXR.axd?r=1_177-id8Yv');
	position: absolute;
	width: 11px;
	height: 11px;
}
.dxcpHuePointerSys {
	background-image: url('/DXR.axd?r=1_179-id8Yv');
	position: absolute;
	width: 35px;
	height: 9px;
}
