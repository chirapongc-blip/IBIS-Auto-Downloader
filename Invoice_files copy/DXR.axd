.dxflItemSys,
.dxflGroupBoxSys
{
    text-align: left;
}
.dxflGroupBoxSys.dxflEmptyGroupBoxSys 
{
    padding: 7px 4px 12px 4px; 
}
.dxflGroupBoxSys
{
    box-sizing: border-box;
    -moz-box-sizing: border-box;
    -webkit-box-sizing: border-box;
}


