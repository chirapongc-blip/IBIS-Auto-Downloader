}

.dxbButton_MetropolisBlue[class~=dxgvCommandColumnItem_MetropolisBlue],
.dxgvStatusBar_MetropolisBlue div.dxbButton_MetropolisBlue,
.dxgvEditFormTable_MetropolisBlue div.dxbButton_MetropolisBlue {
