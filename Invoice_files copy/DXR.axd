.dxrpDisabled_MetropolisBlue td.dxrp {
  color: #b8b8b8;
  cursor: default;
}

.dxrpDisabled_MetropolisBlue.dxrpCollapsed > tbody > tr > td.dxrpHeader_MetropolisBlue {
