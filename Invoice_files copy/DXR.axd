{
    display: table;
    border-spacing: 0;
    border-collapse: separate;
    outline: 0px;
}
.dxtcSys {
    overflow: auto!important;
}
.dxtcSys > .dxtc-content {
    float: none!important;
}
div.dxtcSys > .dxtc-content > div,
div.dxtcSys > .dxtc-content > div > div
{
    width: 100%;
