.dxfm-filterView {
    display: table;
    table-layout: fixed;
    width: 100%;
}
.dxfm-filterView > div {
    display: table-row;
    float: none !important;
    text-overflow: ellipsis;
    overflow: hidden;
}
.dxfm-filterViewRow > div {
    display: table-cell;
