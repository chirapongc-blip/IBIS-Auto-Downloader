}
.dxflVATSys { vertical-align: top; }
.dxflVAMSys { vertical-align: middle; }
.dxflBreakpointGroupSys .dxflVAMSys
{
    margin: auto 0 auto 0;
}
.dxflVABSys { vertical-align: bottom; }
.dxflBreakpointGroupSys .dxflVABSys
{
